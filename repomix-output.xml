            <div className="mb-2 flex items-center gap-3">
              <Heart className="h-8 w-8" style={{ color: '#F4A6B2' }} aria-hidden="true" />
              <h1 className="text-4xl" style={{ fontFamily: 'Playfair Display, serif', color: '#4A5D45', fontWeight: 600 }}>
                My Wishlist
